# LFS-tracked binary types. Pattern committed before any binary lands so the
# first binary commit goes to LFS, not pack. Moving files in or out of LFS
# later requires history rewrite.

# Bag/log files
*.bag        filter=lfs diff=lfs merge=lfs -text
*.mcap       filter=lfs diff=lfs merge=lfs -text
*.db3        filter=lfs diff=lfs merge=lfs -text

# ML model weights and serialized graphs
*.pt         filter=lfs diff=lfs merge=lfs -text
*.pth        filter=lfs diff=lfs merge=lfs -text
*.onnx       filter=lfs diff=lfs merge=lfs -text
*.engine     filter=lfs diff=lfs merge=lfs -text
*.plan       filter=lfs diff=lfs merge=lfs -text
*.tflite     filter=lfs diff=lfs merge=lfs -text
*.pb         filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text

# Isaac / USD scene assets
*.usd        filter=lfs diff=lfs merge=lfs -text
*.usda       filter=lfs diff=lfs merge=lfs -text
*.usdc       filter=lfs diff=lfs merge=lfs -text
*.usdz       filter=lfs diff=lfs merge=lfs -text

# 3D meshes
*.dae        filter=lfs diff=lfs merge=lfs -text
*.stl        filter=lfs diff=lfs merge=lfs -text
*.obj        filter=lfs diff=lfs merge=lfs -text
*.fbx        filter=lfs diff=lfs merge=lfs -text
*.glb        filter=lfs diff=lfs merge=lfs -text
*.gltf       filter=lfs diff=lfs merge=lfs -text
*.ply        filter=lfs diff=lfs merge=lfs -text

# Large textures
*.exr        filter=lfs diff=lfs merge=lfs -text
*.hdr        filter=lfs diff=lfs merge=lfs -text

# Calibration / point-cloud data
*.pcd        filter=lfs diff=lfs merge=lfs -text

# Line ending normalization
*.cpp        text
*.hpp        text
*.h          text
*.c          text
*.py         text
*.md         text
*.yaml       text
*.yml        text
*.json       text
*.xml        text
*.cmake      text
CMakeLists.txt text
